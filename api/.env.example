# Copy to .env next to docker-compose.yml. NEVER commit .env.

# --- control plane ---
POSTGRES_PASSWORD=change-me
SCENEFORGE_WEBHOOK_SECRET=change-me-too

# --- storage (Cloudflare R2 shown; any S3-compatible works) ---
SCENEFORGE_STORAGE=s3
SCENEFORGE_S3_BUCKET=sceneforge
SCENEFORGE_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
SCENEFORGE_PUBLIC_ASSET_BASE=https://assets.example.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- worker/dispatcher ---
# Worker key minted with: python -m sceneforge_api.keycli create --name worker --worker
# (only worker keys may post results to the _result callback)
SCENEFORGE_WORKER_API_KEY=
SCENEFORGE_GPU_WORKER=local        # local | modal | hf_space
SCENEFORGE_API_BASE=http://api:8000
SCENEFORGE_REDIS_URL=redis://queue:6379

# modal adapter
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
SCENEFORGE_MODAL_GPU=T4

# hf_space adapter (demo only)
SCENEFORGE_HF_SPACE=
HF_TOKEN=
